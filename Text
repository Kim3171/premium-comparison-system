Private Function SafeToDeleteRange(ws As Worksheet, startRow As Long, endRow As Long) As Boolean
    ' Check if range contains user data
    ' If yes, ask for confirmation or block
    Dim lastDataRow As Long
    lastDataRow = GetLastDataRow(ws, 1)  ' Find actual data

