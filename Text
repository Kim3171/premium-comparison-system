' Step 2: After any column operation, read anchor data from COMPARE_CONFIG
'         and reposition buttons using stored row, offset, width, height
Sub RepositionButtonsAfterColumnChange(ws As Worksheet)
    Dim configWS As Worksheet
    Set configWS = GetOrCreateConfigSheet
    Dim btn As Object
    Dim btnName As String
    Dim storedRow As Long
    Dim storedOffset As Double
    Dim storedWidth As Double
    Dim storedHeight As Double

    ' Find BUTTON_ANCHORS section in config sheet
    Dim anchorStartRow As Long
    anchorStartRow = FindButtonAnchorStartRow(configWS)

    ' Loop through stored button anchors
    Dim r As Long
    For r = anchorStartRow To anchorStartRow + 50
        btnName = configWS.Cells(r, 1).Value
        If btnName = "" Then Exit For

        storedRow = CLng(configWS.Cells(r, 2).Value)
        storedOffset = CDbl(configWS.Cells(r, 3).Value)
        storedWidth = CDbl(configWS.Cells(r, 4).Value)
        storedHeight = CDbl(configWS.Cells(r, 5).Value)

        ' Find and update the button on the worksheet
        On Error Resume Next
        Set btn = ws.Buttons(btnName)
        On Error GoTo 0

        If Not btn Is Nothing Then
            ' Restore all 4 properties from stored values
            btn.Top = ws.Rows(storedRow).Top
            btn.Left = ws.Range("A1").Left + storedOffset
            btn.Width = storedWidth
            btn.Height = storedHeight
        End If
    Next r
End Sub
