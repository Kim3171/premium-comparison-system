        For col = 1 To lastUIcol
            ' Copy value directly
            ws.Cells(shiftRow, col).Value = ws.Cells(shiftRow + 1, col).Value
            ' Copy color directly
            ws.Cells(shiftRow, col).Interior.Color = ws.Cells(shiftRow + 1, col).Interior.Color
