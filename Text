' Parse "3,5,7" or "3-7" or "3,5-8" into array of row numbers
Private Function ParseRowSelection(input As String, minRow As Long, maxRow As Long) As Long()
    Dim result() As Long
    Dim resultCount As Long
    resultCount = 0

    ' Step 1: Parse all numbers from input string
    Dim parts() As String
    parts = Split(input, ",")

    Dim i As Long
    For i = 0 To UBound(parts)
        Dim part As String
        part = Trim(parts(i))

        If InStr(part, "-") > 0 Then
            ' Handle range like "3-7"
            Dim rangeParts() As String
            rangeParts = Split(part, "-")
            Dim startNum As Long
            Dim endNum As Long
            startNum = CLng(Trim(rangeParts(0)))
            endNum = CLng(Trim(rangeParts(1)))

            Dim j As Long
            For j = startNum To endNum
                ReDim Preserve result(resultCount)
                result(resultCount) = j
                resultCount = resultCount + 1
            Next j
        Else
            ' Handle single number
            ReDim Preserve result(resultCount)
            result(resultCount) = CLng(part)
            resultCount = resultCount + 1
        End If
    Next i

    ' Step 2: Validate - discard any value outside minRow to maxRow
    Dim validResult() As Long
    Dim validCount As Long
    validCount = 0

    For i = 0 To resultCount - 1
        If result(i) >= minRow And result(i) <= maxRow Then
            ReDim Preserve validResult(validCount)
            validResult(validCount) = result(i)
            validCount = validCount + 1
        End If
    Next i

    ' Step 3: If no valid rows, set flag and exit without returning array
    If validCount = 0 Then
        MsgBox "All entered row numbers are outside the valid range of rows " & _
               minRow & " to " & maxRow, vbExclamation
        g_ParseCancelled = True
        Exit Function
    End If

    ParseRowSelection = validResult
End Function

' Sort array in descending order
Private Sub QuickSortDescending(arr() As Long)
    Dim i As Long
    Dim j As Long
    Dim temp As Long

    ' Bubble sort descending (simple and reliable)
    For i = LBound(arr) To UBound(arr) - 1
        For j = i + 1 To UBound(arr)
            If arr(i) < arr(j) Then
                temp = arr(i)
                arr(i) = arr(j)
                arr(j) = temp
            End If
        Next j
    Next i
End Sub
