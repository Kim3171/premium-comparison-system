Private Function HasDataBelowHeader(ws As Worksheet, headerRow As Long) As Boolean
    ' Chỉ check content, không check formatting
    Dim col As Long, firstDataCol As Long

    firstDataCol = 0
    For col = 1 To 50
        If Trim(CStr(ws.Cells(headerRow, col).Value)) <> "" Then
            firstDataCol = col
            Exit For
        End If
    Next col

    If firstDataCol = 0 Then
        HasDataBelowHeader = False
        Exit Function
    End If

    ' Chỉ check content thực, không tính formatting
    HasDataBelowHeader = (Trim(CStr(ws.Cells(headerRow + 1, firstDataCol).Value)) <> "")
End Function
