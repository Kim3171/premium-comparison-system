Private Function ValidateHeaderRow(ws As Worksheet, headerRow As Long) As Boolean
    ' Check if the row contains at least 3 non-empty cells (typical header)
    ' or contains known header keywords like ASSET, ID, NAME, etc.
    Dim col As Long
    Dim nonEmptyCount As Long
    Dim hasKeyword As Boolean

    nonEmptyCount = 0
    For col = 1 To 50
        If Trim(CStr(ws.Cells(headerRow, col).Value)) <> "" Then
            nonEmptyCount = nonEmptyCount + 1
        End If
    Next col

    ' A valid header should have at least 3 non-empty columns
    ' OR contain common header keywords
    ValidateHeaderRow = (nonEmptyCount >= 3)
End Function

Private Function HasDataBelowHeader(ws As Worksheet, headerRow As Long) As Boolean
    ' Check if there's at least 1 data row below the header
    Dim col As Long
    Dim firstDataCol As Long

    ' Find first non-empty column in header row
    firstDataCol = 0
    For col = 1 To 50
        If Trim(CStr(ws.Cells(headerRow, col).Value)) <> "" Then
            firstDataCol = col
            Exit For
        End If
    Next col

    If firstDataCol = 0 Then
        HasDataBelowHeader = False
        Exit Function
    End If

    ' Check if there's data in the row below header
    HasDataBelowHeader = (Trim(CStr(ws.Cells(headerRow + 1, firstDataCol).Value)) <> "")
End Function
